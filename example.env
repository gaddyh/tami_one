# Required: 360dialog phone-number API key
D360_API_KEY=replace_with_your_360dialog_api_key

# Production Direct API base URL:
D360_API_BASE_URL=https://waba-v2.360dialog.io

# For 360dialog sandbox, use this instead:
# D360_API_BASE_URL=https://waba-sandbox.360dialog.io/v1

# Webhook auth mode: none | bearer | basic
# Start with none if configuring from the Hub UI is easier.
WEBHOOK_AUTH_MODE=none

# Bearer auth example:
# WEBHOOK_AUTH_MODE=bearer
# WEBHOOK_BEARER_TOKEN=change_me

# Basic auth example:
# WEBHOOK_AUTH_MODE=basic
# WEBHOOK_BASIC_USER=webhook
# WEBHOOK_BASIC_PASS=change_me

LOG_LEVEL=INFO

# LangSmith observability (optional)
# Local dev: run `langsmith auth login` once — no env vars needed.
# Production: set these:
# LANGSMITH_TRACING_V2=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=echo2

# Per-user conversation history cap (number of messages, default 20)
# CONVERSATION_MAX_MESSAGES=20

# SQLite database file path (relative to project root or absolute)
# Used for local dev when DATABASE_URL is not set
# DATABASE_PATH=tami.db

# PostgreSQL connection URL (Render managed Postgres or any external DB)
# When set, this takes priority over DATABASE_PATH
# DATABASE_URL=postgresql://user:password@host:5432/dbname

GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_TOKEN=your_green_api_instance_token
MAX_GROUP_PARTICIPANTS=3

# Conversation threading & extraction
SESSION_GAP_MINUTES=45
CONVERSATION_DORMANT_HOURS=24
CONVERSATION_CLOSED_DAYS=7
WAITING_REPLY_HOURS=4
MAX_EXTRACTION_ATTEMPTS=3
CONVERSATION_HISTORY_CONTEXT_MESSAGES=10

# Digest endpoint auth (optional — empty = no auth in dev)
# EXPECTED_AUTHORIZATION_HEADER=Bearer your-token-here

# Tenant timezone for reminder scheduling (LLM uses this to resolve relative times)
# Default: Asia/Jerusalem
# TENANT_TIMEZONE=Asia/Jerusalem

# Path to compiled DSPy agent JSON (relative to project root or absolute)
# COMPILED_AGENT_PATH=compiled_agent.json

# Transcription provider: openai | modal
# Default: openai (uses OpenAI Audio API)
# Set to modal to use the Modal Hebrew Whisper GPU endpoint
TRANSCRIPTION_PROVIDER=openai

# Modal transcription endpoint (only required when TRANSCRIPTION_PROVIDER=modal)
# MODAL_TRANSCRIPTION_URL=https://your-workspace--hebrew-whisper-transcription-hebrewwhisper-transcribe.modal.run
# MODAL_TRANSCRIPTION_KEY=your-modal-proxy-key
# MODAL_TRANSCRIPTION_SECRET=your-modal-proxy-secret
# MODAL_TRANSCRIPTION_TIMEOUT_SECONDS=180